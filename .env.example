# Copy this file to `.env` (in the same directory) and fill in real values.
# `.env` is gitignored — never committed.

# ---- ZoomInfo (PKI auth) ----
# Username and Client ID come from your ZoomInfo API admin panel.
ZOOMINFO_USERNAME=
ZOOMINFO_CLIENT_ID=

# Private key — set ONE of the following:
#
#   ZOOMINFO_PRIVATE_KEY_PATH (preferred for local Mac):
#     Path to a .pem file on disk. Most natural for terminal use.
#
#   ZOOMINFO_PRIVATE_KEY (preferred for claude.ai/code or any hosted runner):
#     The full PEM contents pasted directly. Multi-line is fine; if the host
#     strips newlines, auth.py will reconstruct them automatically.
#
ZOOMINFO_PRIVATE_KEY_PATH=./zoominfo_private_key.pem
# ZOOMINFO_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ---- Bright Data ----
# Used for LinkedIn profile verification. Dataset ID is hard-coded in scripts/verify.py.
BRIGHTDATA_API_KEY=

# ---- Firecrawl ----
# Used for local company discovery + company team-page scraping.
FIRECRAWL_API_KEY=

# ---- SEC EDGAR ----
# EDGAR requires a real contact email in the User-Agent header.
SEC_EDGAR_USER_AGENT=Aric Gorman aric@harbingermarketing.com
