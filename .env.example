# Copy this file to `.env` (in the same directory) and fill in real values.
# `.env` is gitignored — never committed.

# ---- ZoomInfo (PKI auth) ----
# Username and Client ID come from your ZoomInfo API admin panel.
# The private key is a .pem file; store the path to it here, not the key contents.
ZOOMINFO_USERNAME=
ZOOMINFO_CLIENT_ID=
ZOOMINFO_PRIVATE_KEY_PATH=./zoominfo_private_key.pem

# ---- Bright Data ----
# Used for LinkedIn profile verification. Dataset ID is hard-coded in scripts/verify.py.
BRIGHTDATA_API_KEY=

# ---- Firecrawl ----
# Used for local company discovery + company team-page scraping.
FIRECRAWL_API_KEY=

# ---- SEC EDGAR ----
# EDGAR requires a real contact email in the User-Agent header.
SEC_EDGAR_USER_AGENT=Aric Gorman aric@harbingermarketing.com
